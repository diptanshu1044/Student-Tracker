NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/studentos
JWT_ACCESS_SECRET=replace_with_long_access_secret
JWT_REFRESH_SECRET=replace_with_long_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REDIS_URL=rediss://default:<UPSTASH_REDIS_PASSWORD>@<UPSTASH_REDIS_HOST>:6379
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
APP_BASE_URL=http://localhost:3000
EMAIL_VERIFICATION_TTL_MINUTES=60
EMAIL_VERIFICATION_MOCK=false
PLANNER_AUTO_CREATE_DEFAULT_PROFILE=true
PLANNER_DEFAULT_PROFILE_NAME=Study Planner
PLANNER_DEFAULT_PROFILE_DESCRIPTION=Default planner profile for quick task capture
PLANNER_DEFAULT_PROFILE_COLOR=#2563eb
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_FROM=noreply@studentos.app
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
DATA_ENCRYPTION_KEY=
