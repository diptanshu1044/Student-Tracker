NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/studentos
JWT_ACCESS_SECRET=replace_with_long_access_secret
JWT_REFRESH_SECRET=replace_with_long_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REDIS_URL=rediss://default:<UPSTASH_REDIS_PASSWORD>@<UPSTASH_REDIS_HOST>:6379
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
APP_BASE_URL=http://localhost:3000
EMAIL_VERIFICATION_TTL_MINUTES=60
EMAIL_VERIFICATION_MOCK=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@studentos.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
DATA_ENCRYPTION_KEY=
